{
  "name": "vibevoice-classroom",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently -n web,server -c blue,green \"npm run dev:web\" \"npm run dev:server\"",
    "dev:web": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "preview:web": "npm --workspace apps/web run preview",
    "dev:server": "python3 -m uvicorn app.main:app --reload --app-dir services/asr-server --host 127.0.0.1 --port 8000"
  },
  "devDependencies": {
    "concurrently": "^9.2.0"
  }
}
