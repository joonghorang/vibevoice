TRANSCRIPTION_PROVIDER=vibevoice
VIBEVOICE_MODEL_ID=microsoft/VibeVoice-ASR-HF
VIBEVOICE_ACOUSTIC_TOKENIZER_ID=microsoft/VibeVoice-AcousticTokenizer
VIBEVOICE_CACHE_DIR=./.models/huggingface
VIBEVOICE_LOCAL_FILES_ONLY=true
GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id
GOOGLE_TRANSLATE_LOCATION=global
GOOGLE_TRANSLATE_GLOSSARY=
GOOGLE_APPLICATION_CREDENTIALS=./.config/gcp/vibevoice-translate.json
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:4173,http://localhost:4173
